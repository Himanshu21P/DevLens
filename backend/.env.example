# App Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (MySQL)
DATABASE_URL="mysql://devlens_user:devlens_password@localhost:3306/devlens"

# Cache Configuration (Redis)
REDIS_URL="redis://localhost:6379"

# Security (JWT)
# Generate strong keys in production, e.g., using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="devlens_jwt_secret_key_change_me_in_production_12345"
JWT_REFRESH_SECRET="devlens_jwt_refresh_secret_key_change_me_in_production_54321"

# AES-256 Encryption Key for sensitive fields (must be 32 bytes/64 hex chars)
# E.g., node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# GitHub API & OAuth Configuration
# Get these from GitHub Settings -> Developer settings -> OAuth Apps
GITHUB_CLIENT_ID="mock_client_id"
GITHUB_CLIENT_SECRET="mock_client_secret"
GITHUB_REDIRECT_URI="http://localhost:3000/oauth/callback"

# Google Gemini API Configuration
# Get your API key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY="mock_gemini_api_key"
